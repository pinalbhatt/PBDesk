{
  "name": "pbdesk-com",
  "version": "1.0.0",
  "description": "PBDesk.com 2019 Nuxt Project",
  "author": "Pinal Bhatt",
  "private": true,
  "scripts": {
    "dev": "nuxt",
    "build": "nuxt build",
    "start": "nuxt start",
    "generate": "nuxt generate",
    "generate:ghp": "DEPLOY_ENV=GH_PAGES nuxt generate",
    "lint": "eslint --ext .js,.vue --ignore-path .gitignore .",
    "lintf": "eslint --fix --ext .js,.vue --ignore-path .gitignore .",
    "precommit": "npm run lint",
    "deploy:ghp": "push-dir --dir=dist --branch=gh-pages --cleanup"
  },
  "dependencies": {
    "cross-env": "5.2.0",
    "nuxt": "2.2.0",
    "@nuxtjs/axios": "5.3.4"
  },
  "devDependencies": {
    "babel-eslint": "^10.0.1",
    "eslint": "^5.0.1",
    "eslint-config-prettier": "^3.1.0",
    "eslint-loader": "^2.0.0",
    "eslint-plugin-prettier": "3.0.0",
    "eslint-plugin-vue": "^4.0.0",
    "nodemon": "^1.11.0",
    "prettier": "1.14.3",
    "push-dir": "^0.4.1"
  }
}
